{
  "name": "semver-existing-max",
  "version": "1.0.3",
  "type": "module",
  "description": "Find existing maximum version of dependency according to semver",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klintonc/semver-existing-max.git"
  },
  "homepage": "https://github.com/klintonc/semver-existing-max",
  "author": "Klinton C. <klinton.chh@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsup",
    "typecheck": "bunx tsc --noEmit",
    "release": "bun run build && bun version patch && git push --follow-tags && bun publish"
  },
  "files": [
    "dist"
  ],
  "bugs": {
    "url": "https://github.com/klintonc/semver-existing-max/issues"
  },
  "keywords": [
    "semver",
    "version",
    "maximum",
    "existing",
    "max",
    "semver-existing-max"
  ],
  "dependencies": {
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
